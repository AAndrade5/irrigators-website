---
import { url } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQ from '../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "The Irrigators | Vancouver Island's Trusted Irrigation Experts",
    "description": "Professional irrigation and landscape lighting services on Vancouver Island since 1990. Spring start-ups, winter blowouts, repairs, installations, and lighting.",
    "url": "https://irrigators.ca"
  }
];

const services = [
  { title: "Spring Irrigation Start-Ups", description: "Kick off the season with a professional sprinkler system start-up. We'll run a full system check including valve testing, controller calibration, pressure checks, and zone optimization, ensuring your irrigation system is ready to keep your lawn lush from day one.", href: url('/services/spring-startups/'), cta: "Book My Spring Start-Up", image: url('/images/services/spring-startup.jpg'), imageAlt: "Irrigators technician performing spring irrigation start-up on Vancouver Island" },
  { title: "Winter Irrigation Blowouts", description: "Avoid costly damage with our expert irrigation winterization services. We use high-power commercial-grade air compression to blow out lines and ensure your irrigation system is safely shut down before the frost hits. Recommended for homes and commercial systems across the Island.", href: url('/services/winter-blowouts/'), cta: "Schedule My Winter Blowout", image: url('/images/services/winter-blowout.jpg'), imageAlt: "Professional irrigation winterization blowout service" },
  { title: "Service Calls & System Repairs", description: "Sprinkler not working? Broken heads, leaky valves, or electrical issues? Our team provides fast, reliable service calls across central Vancouver Island — to diagnose and repair all types of residential and commercial irrigation systems.", href: url('/services/repairs/'), cta: "Request a Service Call", image: url('/images/services/repairs.jpg'), imageAlt: "Irrigation system repair and service call on Vancouver Island" },
  { title: "New Sprinkler System Installations", description: "We design and install custom lawn and garden irrigation systems for homes, strata, and commercial properties across Vancouver Island. Our installations are tailored to your landscape and built to deliver efficient water usage and long-term reliability.", href: url('/services/installations/'), cta: "Get an Installation Quote", image: url('/images/services/installations.jpg'), imageAlt: "New sprinkler system installation with excavation equipment" },
  { title: "Landscape Lighting Installation", description: "Enhance your outdoor space with professionally installed landscape lighting. We design and wire low-voltage, energy-efficient lighting systems that boost curb appeal, safety, and nighttime usability for homes and businesses alike.", href: url('/services/landscape-lighting/'), cta: "Design My Lighting Plan", image: url('/images/services/landscape-lighting.jpg'), imageAlt: "Professional landscape lighting installation on stone steps" },
  { title: "Annual Maintenance Plans", description: "Protect your irrigation investment year-round with an Annual Maintenance Plan. Includes spring start-up, mid-season check, and fall winterization — all scheduled and handled by our certified team. Ideal for homeowners and property managers who want peace of mind without the hassle.", href: url('/services/maintenance-plans/'), cta: "Learn More", image: url('/images/services/maintenance.jpg'), imageAlt: "Well-maintained garden and landscape on Vancouver Island" },
];

const areas = [
  { name: "Ladysmith", href: url('/areas/ladysmith/') },
  { name: "Cedar", href: url('/areas/cedar/') },
  { name: "Nanaimo", href: url('/areas/nanaimo/') },
  { name: "Nanoose Bay", href: url('/areas/nanoose-bay/') },
  { name: "Parksville", href: url('/areas/parksville/') },
  { name: "Errington", href: url('/areas/errington/') },
  { name: "Coombs", href: url('/areas/coombs/') },
  { name: "Qualicum Beach", href: url('/areas/qualicum-beach/') },
  { name: "Bowser", href: url('/areas/bowser/') },
  { name: "Port Alberni", href: url('/areas/port-alberni/') },
  { name: "Lantzville", href: url('/areas/lantzville/') },
];

const faqs = [
  { question: "When should I schedule my spring irrigation start-up?", answer: "We recommend booking your spring start-up in March or early April, depending on the weather. Starting early ensures your sprinkler system is tested and ready before the growing season kicks off. We serve all mid-Island areas including Nanaimo, Port Alberni, and Parksville." },
  { question: "Do I really need a winter blowout for my irrigation system?", answer: "Yes, winter blowouts are essential to prevent frozen and cracked pipes. Even on Vancouver Island, temperatures can dip below freezing, which can cause serious damage to underground lines. Our professional irrigation winterization uses commercial-grade air compressors to protect your system." },
  { question: "Can you repair just one sprinkler head or valve?", answer: "Absolutely. Whether it's a single broken head or a full zone malfunction, our irrigation service calls cover repairs both big and small. We offer fast, reliable support across the central Island region — from Ladysmith to Qualicum Beach." },
  { question: "Do you install irrigation systems for new builds or renovations?", answer: "Yes, we specialize in new sprinkler system installations for everything from new home builds to commercial property upgrades. We'll design a custom system based on your landscaping needs, water pressure, and budget." },
];

const testimonials = [
  { quote: "The team at Irrigators got our system up and running just in time for summer. Super friendly, on time, and knew exactly what they were doing. Highly recommend!", author: "Jamie R.", location: "Nanaimo", rating: 5 },
  { quote: "We had no idea where to start with landscape lighting, but they designed a beautiful layout and installed everything in one afternoon. The yard looks incredible.", author: "Kevin M.", location: "Parksville", rating: 5 },
];

schema.push({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    }
  }))
});
---

<BaseLayout
  title="The Irrigators | Vancouver Island's Trusted Irrigation Experts Since 1990"
  description="Professional irrigation and landscape lighting services on Vancouver Island. Spring start-ups, winter blowouts, repairs, new installations, and landscape lighting. Serving Ladysmith to Bowser since 1990."
  schema={schema}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center">
    <div class="absolute inset-0 bg-cover bg-center bg-brand-900" style={`background-image: url('${import.meta.env.BASE_URL}images/heroes/hero-irrigation.jpg');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-900/80 via-brand-900/70 to-brand-900/60 backdrop-blur-[2px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-3xl">
        <p class="text-lime-300 font-semibold text-sm uppercase tracking-wider mb-4">Since 1990</p>
        <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6 leading-tight" style="font-family: Montserrat, sans-serif;">
          Vancouver Island's Trusted
          <span class="text-lime-300">Irrigation Experts</span>
        </h1>
        <p class="text-lime-100 text-lg lg:text-xl mb-4 leading-relaxed max-w-2xl">
          From spring start-ups to winter blowouts, The Irrigators delivers reliable irrigation and landscape lighting services across Vancouver Island communities.
        </p>
        <p class="text-lime-300/80 text-sm font-medium mb-8">Spring 2026 Bookings Open — Limited Availability</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={url('/contact/')} class="bg-white/95 backdrop-blur text-brand-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-white transition-colors shadow-lg border border-white/50 text-center">
            Get a Free Estimate
          </a>
          <a href="tel:2504687041" class="glass-dark border border-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/20 transition-colors text-center">
            Call 250-468-7041
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-lime-100 to-lime-50"></div>
    <div class="relative glass py-6 border-y border-white/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-center gap-6 lg:gap-12 text-sm text-brand-900">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="font-medium">35+ Years Experience</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="font-medium">Licensed & Insured</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="font-medium">Based in Coombs, BC</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            <span class="font-medium">Indigenous-Owned Business</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-16 lg:py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider mb-3">Why Choose Us</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6" style="font-family: Montserrat, sans-serif;">35+ Years of Exceptional Irrigation Solutions</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Since 1990, The Irrigators has been the backbone of healthy lawns and illuminated landscapes across Vancouver Island. Whether you're maintaining a tidy residential yard or managing multi-acre commercial grounds, our systems are built to perform, season after season.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Our commitment goes beyond sprinkler heads and timers. We specialize in tailored irrigation design, seasonal system maintenance, and landscape lighting that brings your property to life after dark. Every service is backed by local expertise, unmatched reliability, and a deep respect for your time and investment.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Join hundreds of Island homeowners, property managers, and contractors who trust The Irrigators to keep things flowing — cleanly, efficiently, and professionally.
          </p>
          <a href={url('/contact/')} class="inline-flex items-center gap-2 text-brand-900 font-semibold hover:underline">
            Talk to an irrigation expert
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="glass rounded-2xl p-8 lg:p-10">
          <h3 class="text-2xl font-bold text-gray-900 mb-2" style="font-family: Montserrat, sans-serif;">Get Your Free Estimate</h3>
          <p class="text-gray-600 mb-6">Tell us about your property and we'll recommend the right solution.</p>
          <div class="space-y-4">
            <a href={url('/contact/')} class="block text-center bg-brand-900/90 backdrop-blur text-white px-6 py-3.5 rounded-lg font-semibold text-lg hover:bg-brand-800 transition-colors border border-brand-700/50 shadow-lg shadow-brand-900/25">
              Request a Free Estimate
            </a>
            <p class="text-center text-sm text-gray-500">Or call <a href="tel:2504687041" class="font-semibold text-brand-900">250-468-7041</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="relative py-16 lg:py-24 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-stone-50 to-stone-100/80"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider mb-3">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4" style="font-family: Montserrat, sans-serif;">Our Services</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">Professional irrigation and lighting services for homes, strata, and commercial spaces, backed by 35+ years of local expertise.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section id="areas" class="py-16 lg:py-24 px-4">
    <div class="max-w-7xl mx-auto text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4" style="font-family: Montserrat, sans-serif;">Areas We Serve</h2>
      <p class="text-gray-600 text-lg mb-4 max-w-2xl mx-auto">We provide professional irrigation and landscape lighting services to homes, strata properties, and businesses throughout Vancouver Island. Based in Coombs, we travel to communities across the mid-Island region.</p>
      <p class="text-gray-500 text-sm mb-10">1766 Alberni Highway, Coombs, BC V0R 1M0</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {areas.map((area) => (
          <a href={area.href} class="glass rounded-xl px-4 py-4 font-medium text-gray-900 hover:shadow-lg hover:shadow-brand-900/10 hover:text-brand-900 transition-all duration-300">
            {area.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="relative py-16 lg:py-24 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-brand-900" style={`background-image: url('${import.meta.env.BASE_URL}images/heroes/hero-irrigation.jpg');`}></div>
    <div class="absolute inset-0 bg-brand-900/85 backdrop-blur-[3px]"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">What Our Customers Are Saying</h2>
        <p class="text-lime-200 text-lg max-w-2xl mx-auto">Real feedback from homeowners and property managers across Vancouver Island.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {testimonials.map((t) => (
          <div class="glass-dark rounded-2xl p-8">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-5 h-5 text-lime-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <blockquote class="text-white leading-relaxed mb-4 italic">"{t.quote}"</blockquote>
            <div class="text-sm">
              <span class="text-white font-medium">{t.author}</span>
              <span class="text-lime-300"> — {t.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faqs" class="py-16 lg:py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
      <p class="text-gray-500 text-center mb-8">Please reach us at <a href="mailto:info@irrigators.ca" class="text-brand-900 hover:underline">info@irrigators.ca</a> if you cannot find an answer to your question.</p>
      <FAQ items={faqs} />
    </div>
  </section>

  <!-- Raincoast Group Banner -->
  <section class="py-12 px-4 bg-stone-100/50">
    <div class="max-w-4xl mx-auto">
      <a href={url('/companies/')} class="glass rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6 hover:shadow-lg transition-all group">
        <img src={url("/images/raincoast-logo.png")} alt="Raincoast Erosion Control Ltd." class="h-16 w-auto shrink-0" />
        <div class="text-center sm:text-left">
          <h3 class="font-bold text-gray-900 text-lg mb-1 group-hover:text-brand-900 transition-colors" style="font-family: Montserrat, sans-serif;">Part of the Raincoast Group</h3>
          <p class="text-gray-600 text-sm">An Indigenous-owned family of companies on Vancouver Island — including Raincoast Erosion Control, Elite Lawn Care, The Irrigators, and more.</p>
        </div>
        <svg class="w-6 h-6 text-brand-900 shrink-0 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
