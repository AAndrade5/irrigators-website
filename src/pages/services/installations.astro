---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Sprinkler System Installation",
    "provider": { "@id": "https://irrigators.ca/#business" },
    "areaServed": { "@type": "State", "name": "British Columbia" },
    "description": "Custom sprinkler system design and installation for homes and commercial properties on Vancouver Island."
  }
];

const faqs = [
  { question: "How long does a new irrigation system installation take?", answer: "Most residential installations take 1-3 days depending on property size and complexity. Commercial and strata projects may take longer. We'll give you a clear timeline upfront." },
  { question: "Do you handle the design as well?", answer: "Yes. We design every system from scratch based on your property's layout, soil type, sun exposure, plant types, and water pressure. No cookie-cutter plans — every system is custom." },
  { question: "What brands do you install?", answer: "We install all major brands including Rain Bird, Hunter, and Toro. We'll recommend the best fit for your property and budget." },
  { question: "Do you install systems for new home builds?", answer: "Absolutely. We work with builders and homeowners on new construction projects. The ideal time to install irrigation is before the landscaping goes in, but we can retrofit existing properties too." },
];
---

<BaseLayout
  title="Sprinkler System Installation on Vancouver Island | The Irrigators"
  description="Custom sprinkler system design and installation for homes, strata, and commercial properties on Vancouver Island. Efficient water usage and long-term reliability."
  schema={schema}
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-cover bg-center bg-brand-900" style={`background-image: url('${import.meta.env.BASE_URL}images/heroes/hero-irrigation.jpg');`}></div>
    <div class="absolute inset-0 bg-brand-900/75 backdrop-blur-[2px]"></div>
    <div class="relative max-w-7xl mx-auto">
      <nav class="text-gray-500 text-sm mb-4">
        <a href={url('/')} class="hover:text-brand-200">Home</a> / <a href={url('/services/')} class="hover:text-brand-200">Services</a> / New Installations
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">New Sprinkler System Installations</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Custom-designed irrigation systems built for your landscape, your water pressure, and your budget. Homes, strata, and commercial properties across Vancouver Island.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-4" style="font-family: Montserrat, sans-serif;">Irrigation Systems Built to Last</h2>
      <p class="text-gray-600 leading-relaxed mb-6">A properly designed irrigation system does more than keep your lawn green — it conserves water, protects your landscaping investment, and adds real value to your property. We design and install custom systems for everything from small residential yards to multi-acre commercial properties.</p>

      <p class="text-gray-600 leading-relaxed mb-6">Every installation starts with a site visit. We assess your property's layout, soil conditions, sun and shade patterns, existing plantings, and water supply. From there, we design a system that delivers the right amount of water to the right places — no wasted water, no dry spots.</p>

      <h2 class="text-2xl font-bold text-gray-900 mb-4 mt-10" style="font-family: Montserrat, sans-serif;">Our Installation Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-gray-900 mb-1">1. Site Assessment</h3>
          <p class="text-gray-600 text-sm">We visit your property to evaluate layout, water pressure, soil type, and landscaping needs. This is free and no-obligation.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-gray-900 mb-1">2. Custom Design</h3>
          <p class="text-gray-600 text-sm">We design a zone layout with head placement, pipe routing, and controller programming tailored to your property.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-gray-900 mb-1">3. Professional Installation</h3>
          <p class="text-gray-600 text-sm">Our crew installs the full system — trenching, pipe laying, head installation, valve boxes, and controller wiring.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-gray-900 mb-1">4. Testing & Walkthrough</h3>
          <p class="text-gray-600 text-sm">Every zone is tested for coverage and pressure. We walk you through the controller and answer all your questions.</p>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mb-4 mt-10" style="font-family: Montserrat, sans-serif;">We Install For</h2>
      <ul class="space-y-3 mb-10">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-700 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-600">Residential homes — new builds and retrofits</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-700 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-600">Strata and multi-unit properties</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-700 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-600">Commercial properties and business grounds</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-700 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-gray-600">Parks, sports fields, and community spaces</span>
        </li>
      </ul>

      <div class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
        <FAQ items={faqs} />
      </div>
    </div>
  </section>

  <CTABanner title="Get a Custom Installation Quote" subtitle="Tell us about your property and we'll design a system that fits. Free site assessment, no obligation." />
</BaseLayout>
