---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Irrigation System Repair",
    "provider": { "@id": "https://irrigators.ca/#business" },
    "areaServed": { "@type": "State", "name": "British Columbia" },
    "description": "Fast, reliable irrigation repair and service calls on Vancouver Island."
  }
];

const faqs = [
  { question: "How quickly can you come out for a repair?", answer: "We typically respond within 1-2 business days for standard service calls. For emergencies like major leaks or water waste, we prioritize same-day or next-day service when possible." },
  { question: "Do you repair all brands of irrigation systems?", answer: "Yes. Our technicians have experience with all major brands including Rain Bird, Hunter, Toro, Irritrol, and Weathermatic. We carry common replacement parts on our service vehicles." },
  { question: "Can you fix just one broken sprinkler head?", answer: "Absolutely. Whether it's a single head replacement or a full zone rebuild, no job is too small. We charge fairly for what the job actually requires." },
  { question: "What if you find additional problems during the repair?", answer: "We'll diagnose the full issue and explain everything before doing any additional work. You'll always know the cost before we proceed — no surprises." },
];
---

<BaseLayout
  title="Irrigation Repairs & Service Calls on Vancouver Island | The Irrigators"
  description="Fast, reliable irrigation system repairs on Vancouver Island. Broken heads, leaky valves, electrical issues — we diagnose and fix all types of sprinkler problems."
  schema={schema}
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-dark-950"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-lime-500/8 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <nav class="text-gray-500 text-sm mb-4">
        <a href={url('/')} class="hover:text-lime-400">Home</a> / <a href={url('/services/')} class="hover:text-lime-400">Services</a> / Repairs & Service Calls
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Service Calls & System Repairs</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Sprinkler not working? Broken heads, leaky valves, or electrical issues? We provide fast, reliable repair services across central Vancouver Island.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Fast, Expert Irrigation Repairs</h2>
      <p class="text-gray-400 leading-relaxed mb-6">When your irrigation system breaks down, you need it fixed fast. A broken head wastes water. A leaky valve runs up your bill. A wiring fault leaves zones dry while your lawn suffers. Our technicians carry common parts on every truck and can diagnose and repair most issues in a single visit.</p>

      <p class="text-gray-400 leading-relaxed mb-6">With over 35 years servicing irrigation systems across Vancouver Island — from older residential setups in Nanaimo to modern commercial installations in Parksville and Qualicum Beach — we've seen and fixed every type of problem. We'll find the issue, explain it clearly, and get your system running right.</p>

      <h2 class="text-2xl font-bold text-white mb-4 mt-10" style="font-family: Montserrat, sans-serif;">Common Repairs We Handle</h2>
      <div class="space-y-4 mb-10">
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-white mb-1">Broken Sprinkler Heads</h3>
          <p class="text-gray-400 text-sm">Cracked, stuck, or misaligned heads are the most common issue. We replace and adjust heads for proper coverage and pattern.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-white mb-1">Leaky Valves & Diaphragms</h3>
          <p class="text-gray-400 text-sm">Valves that won't open, won't close, or weep constantly. We rebuild or replace valve internals to restore proper operation.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-white mb-1">Controller & Wiring Issues</h3>
          <p class="text-gray-400 text-sm">Dead zones, erratic schedules, or a controller that won't respond. We trace wiring faults and repair or replace controllers.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-white mb-1">Pipe Leaks & Breaks</h3>
          <p class="text-gray-400 text-sm">Underground leaks from frost damage, root intrusion, or old fittings. We locate and repair damaged sections.</p>
        </div>
        <div class="glass rounded-2xl p-5">
          <h3 class="font-bold text-white mb-1">Low Pressure & Coverage Gaps</h3>
          <p class="text-gray-400 text-sm">System not reaching full coverage? We diagnose pressure issues, nozzle blockages, and zone layout problems.</p>
        </div>
      </div>

      <div class="mt-12">
        <h2 class="text-2xl font-bold text-white mb-6" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
        <FAQ items={faqs} />
      </div>
    </div>
  </section>

  <CTABanner title="Need a Repair? We're On It." subtitle="Send us a message or call — we'll get you booked for a service call and your system running right." />
</BaseLayout>
