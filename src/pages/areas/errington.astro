---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Irrigation Services",
    "provider": { "@id": "https://irrigators.ca/#business" },
    "areaServed": { "@type": "City", "name": "Errington", "containedInPlace": { "@type": "State", "name": "British Columbia" } },
    "description": "Professional irrigation and landscape lighting services in Errington, BC."
  }
];

const faqs = [
  { question: "Can you design irrigation for large rural lots in Errington?", answer: "Yes. Large rural properties are common in Errington and we design systems for them regularly. Whether you need to irrigate a big lawn, a vegetable garden, a hobby farm, or a mix of all three, we'll design zones that cover your property efficiently. We work with both municipal water and well water sources." },
  { question: "My Errington property is on well water — can you still install irrigation?", answer: "Absolutely. Many Errington properties rely on wells. We test your well's flow rate and pressure before designing anything. The system is sized to work within your well's capacity, with scheduling that avoids overtaxing it. We can also install a holding tank system if your well recovery rate is limited but you need higher peak flow." },
  { question: "How close is Errington to your shop?", answer: "Errington is right next door to Coombs — we're literally neighbours. It's one of the closest communities to our base at 1766 Alberni Highway, which means fast response times and minimal travel charges." },
  { question: "Do you install drip irrigation for Errington vegetable gardens and farms?", answer: "Yes. Errington has a strong agricultural and gardening community, and drip irrigation is ideal for vegetable plots, berry patches, and small farm operations. Drip delivers water directly to the root zone, reducing waste and keeping foliage dry. We install both permanent and seasonal drip systems." },
];
---

<BaseLayout
  title="Irrigation Services in Errington, BC | The Irrigators"
  description="Professional irrigation and landscape lighting in Errington, BC. Spring start-ups, winter blowouts, repairs, and new installations. Serving Errington since 1990."
  schema={schema}
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-cover bg-center bg-brand-900" style={`background-image: url('${import.meta.env.BASE_URL}images/heroes/hero-irrigation.jpg');`}></div>
    <div class="absolute inset-0 bg-brand-900/75 backdrop-blur-[2px]"></div>
    <div class="relative max-w-7xl mx-auto">
      <nav class="text-gray-500 text-sm mb-4">
        <a href={url('/')} class="hover:text-brand-200">Home</a> / <a href={url('/areas/')} class="hover:text-brand-200">Service Areas</a> / Errington
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Irrigation Services in Errington, BC</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Errington's rural properties and hobby farms need irrigation systems designed for larger lots and well water. We're right next door in Coombs — your local irrigation experts.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-4" style="font-family: Montserrat, sans-serif;">Your Neighbour for Irrigation Service</h2>
      <p class="text-gray-600 leading-relaxed mb-6">Errington is a rural community west of Parksville with a character all its own — larger lots, hobby farms, serious vegetable gardens, and homeowners who value self-sufficiency. Many properties here are on well water, and the bigger lot sizes mean irrigation systems need to be thoughtfully designed to cover more ground without overwhelming the water supply.</p>
      <p class="text-gray-600 leading-relaxed mb-6">As your next-door neighbour based in Coombs, we know Errington's conditions intimately. The mix of clay and rocky soil, the well water considerations, and the diverse irrigation needs — from lawns and ornamental beds to food production and orchard watering — are all part of our daily work. We design systems that work with your water source, cover your property efficiently, and hold up to the demands of rural use.</p>

      <h2 class="text-2xl font-bold text-gray-900 mb-4 mt-10" style="font-family: Montserrat, sans-serif;">Services Available in Errington</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
        <a href={url('/services/spring-startups/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Spring Irrigation Start-Ups
        </a>
        <a href={url('/services/winter-blowouts/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Winter Irrigation Blowouts
        </a>
        <a href={url('/services/repairs/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Repairs & Service Calls
        </a>
        <a href={url('/services/installations/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          New Sprinkler Installations
        </a>
        <a href={url('/services/landscape-lighting/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Landscape Lighting
        </a>
        <a href={url('/services/maintenance-plans/')} class="flex items-center gap-2 text-gray-600 hover:text-brand-900 transition-colors p-3 rounded-lg hover:bg-brand-50">
          <svg class="w-4 h-4 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Annual Maintenance Plans
        </a>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABanner title="Get a Free Estimate for Your Errington Property" subtitle="We're right next door in Coombs. Rural lots, well water systems, hobby farms — we handle it all. Call or request your free estimate." />
</BaseLayout>
