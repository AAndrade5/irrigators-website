---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Irrigation Services",
    "provider": { "@id": "https://irrigators.ca/#business" },
    "areaServed": { "@type": "City", "name": "Port Alberni", "containedInPlace": { "@type": "State", "name": "British Columbia" } },
    "description": "Professional irrigation and landscape lighting services in Port Alberni, BC."
  }
];

const faqs = [
  { question: "Do you really service Port Alberni? Isn't it far from your base?", answer: "Port Alberni is about 45 minutes from our Coombs shop via Highway 4 — a route we know well. We schedule Port Alberni work on dedicated days to serve the community efficiently. Many of our Port Alberni clients are on annual maintenance plans, which makes scheduling seamless." },
  { question: "Port Alberni gets more rain than the east coast — do I still need irrigation?", answer: "Yes. While the Alberni Valley receives more rainfall overall, summers are still dry enough that lawns and gardens need supplemental watering. The valley's warm summer temperatures and long daylight hours mean properties dry out quickly once the rain stops. A well-designed system keeps everything green through July and August." },
  { question: "Can you install a new irrigation system for my Port Alberni home?", answer: "Absolutely. We handle full installations in Port Alberni — from initial property assessment and system design to trenching, pipe installation, head placement, controller programming, and final walkthrough. We coordinate Port Alberni installations to minimize trips and keep your project on schedule." },
  { question: "What about commercial irrigation in Port Alberni?", answer: "We service commercial properties including strata complexes, business parks, and municipal green spaces. Port Alberni's growing community means more commercial landscaping that needs professional irrigation. We design systems scaled for commercial use with the reliability businesses need." },
];
---

<BaseLayout
  title="Irrigation Services in Port Alberni, BC | The Irrigators"
  description="Professional irrigation and landscape lighting in Port Alberni, BC. Spring start-ups, winter blowouts, repairs, and new installations. Serving Port Alberni since 1990."
  schema={schema}
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-dark-950"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-lime-500/8 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <nav class="text-gray-500 text-sm mb-4">
        <a href={url('/')} class="hover:text-lime-400">Home</a> / <a href={url('/areas/')} class="hover:text-lime-400">Service Areas</a> / Port Alberni
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Irrigation Services in Port Alberni, BC</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Port Alberni is a growing west coast community that deserves professional irrigation service. Just 45 minutes from our Coombs base, we bring 35+ years of expertise to the Alberni Valley.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Professional Irrigation for the Alberni Valley</h2>
      <p class="text-gray-400 leading-relaxed mb-6">Port Alberni is Vancouver Island's west coast hub — a growing community in the heart of the Alberni Valley with a mix of established residential neighbourhoods, new developments, and commercial properties. While the valley is known for higher rainfall than the east coast, the summers still get dry and warm enough that irrigation is essential for maintaining healthy lawns and gardens. The valley's fertile soil and warmer summer microclimate actually make for excellent growing conditions when water is managed properly.</p>
      <p class="text-gray-400 leading-relaxed mb-6">We're located about 45 minutes east in Coombs, right on Highway 4, and we've been making the trip to service Port Alberni properties since 1990. We schedule dedicated service days for the Alberni Valley to serve our clients efficiently. Whether you're a homeowner looking to keep your lawn green through the dry months, a strata complex needing professional system management, or a new-build project requiring a complete irrigation installation, we bring the same expertise and reliability to Port Alberni that we deliver across our entire service area.</p>

      <h2 class="text-2xl font-bold text-white mb-4 mt-10" style="font-family: Montserrat, sans-serif;">Services Available in Port Alberni</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
        <a href={url('/services/spring-startups/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Spring Irrigation Start-Ups
        </a>
        <a href={url('/services/winter-blowouts/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Winter Irrigation Blowouts
        </a>
        <a href={url('/services/repairs/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Repairs & Service Calls
        </a>
        <a href={url('/services/installations/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          New Sprinkler Installations
        </a>
        <a href={url('/services/landscape-lighting/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Landscape Lighting
        </a>
        <a href={url('/services/maintenance-plans/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Annual Maintenance Plans
        </a>
      </div>

      <h2 class="text-2xl font-bold text-white mb-6" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABanner title="Get a Free Estimate for Your Port Alberni Property" subtitle="We make dedicated trips to the Alberni Valley every week. Residential, commercial, or strata — call us or request your free estimate." />
</BaseLayout>
