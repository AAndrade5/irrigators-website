---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQ from '../../components/FAQ.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Irrigation Services",
    "provider": { "@id": "https://irrigators.ca/#business" },
    "areaServed": { "@type": "City", "name": "Qualicum Beach", "containedInPlace": { "@type": "State", "name": "British Columbia" } },
    "description": "Professional irrigation and landscape lighting services in Qualicum Beach, BC."
  }
];

const faqs = [
  { question: "Do you service the many garden properties in Qualicum Beach?", answer: "Absolutely. Qualicum Beach is known for its beautiful gardens, and many homeowners here invest significantly in their landscaping. We design irrigation systems with dedicated zones for ornamental beds, perennial borders, vegetable gardens, and lawns — each with the right head type and watering schedule." },
  { question: "Can you maintain an irrigation system I didn't install?", answer: "Yes. We service all brands and types of irrigation systems, regardless of who installed them. We'll assess your existing system, identify any issues, and bring it up to peak performance. Many of our Qualicum Beach clients came to us after their original installer left the area." },
  { question: "What about watering restrictions in Qualicum Beach?", answer: "The Town of Qualicum Beach may implement watering restrictions during dry summers. A well-designed irrigation system actually helps you comply — smart controllers can be programmed for specific watering days and times, and efficient heads reduce the water you need. We set up systems to work within local regulations." },
  { question: "Do you offer landscape lighting in Qualicum Beach?", answer: "Yes. Qualicum Beach properties — especially those with mature trees, garden pathways, and heritage architecture — look stunning with professional landscape lighting. We install low-voltage LED systems that highlight your property's best features and improve nighttime safety along walkways and driveways." },
];
---

<BaseLayout
  title="Irrigation Services in Qualicum Beach, BC | The Irrigators"
  description="Professional irrigation and landscape lighting in Qualicum Beach, BC. Spring start-ups, winter blowouts, repairs, and new installations. Serving Qualicum Beach since 1990."
  schema={schema}
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-dark-950"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-lime-500/8 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <nav class="text-gray-500 text-sm mb-4">
        <a href={url('/')} class="hover:text-lime-400">Home</a> / <a href={url('/areas/')} class="hover:text-lime-400">Service Areas</a> / Qualicum Beach
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Irrigation Services in Qualicum Beach, BC</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Qualicum Beach is famous for its gardens and well-maintained properties. We provide the irrigation expertise to keep them that way — professional service from a team just up the road.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Keeping Qualicum Beach Gardens Thriving</h2>
      <p class="text-gray-400 leading-relaxed mb-6">Qualicum Beach has earned its reputation as one of Vancouver Island's most beautiful seaside communities. The town's residents — many of them avid gardeners — maintain some of the finest residential landscapes on the Island. This commitment to property care means irrigation isn't optional here; it's essential. The warm, dry summers that make Qualicum Beach such a pleasant place to live also mean that without proper watering, even established gardens can suffer.</p>
      <p class="text-gray-400 leading-relaxed mb-6">We're based just minutes away in Coombs and have been servicing Qualicum Beach properties since our founding in 1990. We understand the mix of property types here — from heritage homes in the village centre with mature landscaping to newer developments and retirement communities with strata-managed systems. Our team designs, installs, and maintains irrigation systems that deliver the right amount of water to every corner of your property, efficiently and reliably.</p>

      <h2 class="text-2xl font-bold text-white mb-4 mt-10" style="font-family: Montserrat, sans-serif;">Services Available in Qualicum Beach</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
        <a href={url('/services/spring-startups/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Spring Irrigation Start-Ups
        </a>
        <a href={url('/services/winter-blowouts/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Winter Irrigation Blowouts
        </a>
        <a href={url('/services/repairs/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Repairs & Service Calls
        </a>
        <a href={url('/services/installations/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          New Sprinkler Installations
        </a>
        <a href={url('/services/landscape-lighting/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Landscape Lighting
        </a>
        <a href={url('/services/maintenance-plans/')} class="flex items-center gap-2 text-gray-400 hover:text-lime-400 transition-colors p-3 rounded-lg hover:bg-white/5">
          <svg class="w-4 h-4 text-lime-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Annual Maintenance Plans
        </a>
      </div>

      <h2 class="text-2xl font-bold text-white mb-6" style="font-family: Montserrat, sans-serif;">Frequently Asked Questions</h2>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABanner title="Get a Free Estimate for Your Qualicum Beach Property" subtitle="From heritage homes to strata complexes, we keep Qualicum Beach's gardens in top form. Contact us for a free estimate." />
</BaseLayout>
