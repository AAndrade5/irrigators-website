---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';

const areas = [
  { name: "Ladysmith", href: url('/areas/ladysmith/'), desc: "Southern terminus of our service area" },
  { name: "Cedar", href: url('/areas/cedar/'), desc: "South Nanaimo community" },
  { name: "Nanaimo", href: url('/areas/nanaimo/'), desc: "Vancouver Island's Hub City" },
  { name: "Lantzville", href: url('/areas/lantzville/'), desc: "Coastal community north of Nanaimo" },
  { name: "Nanoose Bay", href: url('/areas/nanoose-bay/'), desc: "Waterfront community between Nanaimo and Parksville" },
  { name: "Parksville", href: url('/areas/parksville/'), desc: "Beach community on the east coast" },
  { name: "Qualicum Beach", href: url('/areas/qualicum-beach/'), desc: "Seaside town known for its gardens" },
  { name: "Errington", href: url('/areas/errington/'), desc: "Rural community west of Parksville" },
  { name: "Coombs", href: url('/areas/coombs/'), desc: "Our home base" },
  { name: "Bowser", href: url('/areas/bowser/'), desc: "Coastal community north of Qualicum" },
  { name: "Port Alberni", href: url('/areas/port-alberni/'), desc: "West coast hub in the Alberni Valley" },
];
---

<BaseLayout
  title="Service Areas | The Irrigators — Vancouver Island Irrigation Services"
  description="The Irrigators serves communities across central Vancouver Island. Irrigation and landscape lighting services from Ladysmith to Bowser, including Nanaimo, Parksville, and Port Alberni."
>
  <section class="relative overflow-hidden py-16 lg:py-20 px-4">
    <div class="absolute inset-0 bg-dark-950"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-lime-500/8 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">Areas We Serve</h1>
      <p class="text-gray-400 text-lg max-w-2xl">Based in Coombs, we provide professional irrigation and landscape lighting services to communities across central Vancouver Island.</p>
    </div>
  </section>

  <section class="py-16 lg:py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <a href={area.href} class="group glass rounded-2xl p-6 hover:shadow-xl hover:shadow-lime-500/5 transition-all duration-300 hover:border-lime-500/20">
            <h3 class="text-xl font-bold text-white mb-1 group-hover:text-lime-400 transition-colors" style="font-family: Montserrat, sans-serif;">{area.name}</h3>
            <p class="text-gray-500 text-sm mb-3">{area.desc}</p>
            <span class="text-lime-500 font-semibold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              View Services
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center">
        <div class="glass rounded-2xl p-8 max-w-2xl mx-auto">
          <h2 class="text-xl font-bold text-white mb-2" style="font-family: Montserrat, sans-serif;">Don't see your area?</h2>
          <p class="text-gray-400 mb-4">We may still be able to help. Contact us and we'll let you know if we can service your location.</p>
          <a href={url('/contact/')} class="inline-flex items-center gap-2 text-lime-500 font-semibold hover:text-lime-400 transition-colors">
            Get in touch
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
