---
interface Props {
  title: string;
  description: string;
  href: string;
  cta?: string;
}
const { title, description, href, cta = "Learn More" } = Astro.props;
---

<a href={href} class="group block glass rounded-2xl p-6 hover:shadow-xl hover:shadow-lime-500/5 transition-all duration-300 border border-white/5 hover:border-lime-500/20">
  <h3 class="text-xl font-bold text-white mb-2 group-hover:text-lime-400 transition-colors" style="font-family: Montserrat, sans-serif;">{title}</h3>
  <p class="text-gray-400 text-sm leading-relaxed mb-4">{description}</p>
  <span class="text-lime-500 font-semibold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
    {cta}
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </span>
</a>
