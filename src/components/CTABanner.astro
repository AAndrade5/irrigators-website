---
import { url } from '../utils/paths';

interface Props {
  title?: string;
  subtitle?: string;
}
const { title = "Need Irrigation Service? Let's Get It Done.", subtitle = "Whether you're booking a spring start-up, need an urgent repair, or want to light up your landscape — we're here to help. Serving central Vancouver Island since 1990." } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-cover bg-center bg-brand-900" style={`background-image: url('${import.meta.env.BASE_URL}images/heroes/hero-irrigation.jpg');`}></div>
  <div class="absolute inset-0 bg-brand-900/80 backdrop-blur-sm"></div>
  <div class="relative py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">{title}</h2>
      <p class="text-lime-200 text-lg mb-8 max-w-2xl mx-auto">{subtitle}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={url('/contact/')} class="bg-white/95 backdrop-blur text-brand-900 px-8 py-3.5 rounded-lg font-semibold text-lg hover:bg-white transition-colors shadow-lg border border-white/50">
          Get a Free Estimate
        </a>
        <a href="tel:2504687041" class="glass-dark border border-white/30 text-white px-8 py-3.5 rounded-lg font-semibold text-lg hover:bg-white/20 transition-colors">
          Call 250-468-7041
        </a>
      </div>
    </div>
  </div>
</section>
