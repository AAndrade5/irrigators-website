---
import { url } from '../utils/paths';

interface Props {
  title?: string;
  subtitle?: string;
}
const { title = "Need Irrigation Service? Let's Get It Done.", subtitle = "Whether you're booking a spring start-up, need an urgent repair, or want to light up your landscape — we're here to help. Serving central Vancouver Island since 1990." } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-dark-950"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-lime-500/10 via-transparent to-lime-500/5"></div>
  <div class="relative py-16 px-4 border-t border-b border-lime-500/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4" style="font-family: Montserrat, sans-serif;">{title}</h2>
      <p class="text-gray-400 text-lg mb-8 max-w-2xl mx-auto">{subtitle}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={url('/contact/')} class="bg-lime-500/90 backdrop-blur text-dark-900 px-8 py-3.5 rounded-lg font-semibold text-lg hover:bg-lime-400 transition-colors shadow-lg shadow-lime-500/20 border border-lime-400/50">
          Get a Free Estimate
        </a>
        <a href="tel:2504687041" class="glass border border-white/10 text-white px-8 py-3.5 rounded-lg font-semibold text-lg hover:bg-white/10 transition-colors">
          Call 250-468-7041
        </a>
      </div>
    </div>
  </div>
</section>
