---
interface Props {
  items: { question: string; answer: string }[];
}
const { items } = Astro.props;
---

<div class="space-y-4">
  {items.map((item, i) => (
    <details class="group glass rounded-xl overflow-hidden">
      <summary class="flex items-center justify-between cursor-pointer px-6 py-4 font-medium text-gray-100 hover:bg-white/5 rounded-xl transition-colors">
        <span>{item.question}</span>
        <svg class="w-5 h-5 text-lime-500 transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </summary>
      <div class="px-6 pb-4 text-gray-400 leading-relaxed">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
